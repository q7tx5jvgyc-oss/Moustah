#import <UIKit/UIKit.h>

@interface TouchRecorder : NSObject
+ (instancetype)shared;
- (void)start;
- (void)stop;
- (void)recordPoint:(CGPoint)p type:(NSString *)type;
@end

@implementation TouchRecorder {
    NSMutableArray *_events;
}

+ (instancetype)shared {
    static TouchRecorder *r;
    static dispatch_once_t onceToken;
    dispatch_once(&onceToken, ^{
        r = [TouchRecorder new];
    });
    return r;
}

- (instancetype)init {
    if (self = [super init]) {
        _events = [NSMutableArray new];
    }
    return self;
}

- (void)start {
    [_events removeAllObjects];
    NSLog(@"🎥 Recording Started");
}

- (void)stop {
    NSLog(@"🎥 Recording Stopped: %lu events", (unsigned long)_events.count);
}

- (void)recordPoint:(CGPoint)p type:(NSString *)type {
    NSDictionary *event = @{
        @"x": @(p.x),
        @"y": @(p.y),
        @"type": type
    };
    [_events addObject:event];
}

@end
