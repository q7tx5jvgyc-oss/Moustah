#import <UIKit/UIKit.h>

@implementation ControlPanel

+ (UIView *)create {

    UIView *p = [[UIView alloc] initWithFrame:CGRectMake(40, 300, 260, 320)];
    p.backgroundColor = [[UIColor blackColor] colorWithAlphaComponent:0.7];
    p.layer.cornerRadius = 15;

    UIButton *start = [UIButton buttonWithType:UIButtonTypeSystem];
    start.frame = CGRectMake(20, 20, 220, 40);
    [start setTitle:@"Start Recording" forState:UIControlStateNormal];

    UIButton *stop = [UIButton buttonWithType:UIButtonTypeSystem];
    stop.frame = CGRectMake(20, 80, 220, 40);
    [stop setTitle:@"Stop" forState:UIControlStateNormal];

    UIButton *play = [UIButton buttonWithType:UIButtonTypeSystem];
    play.frame = CGRectMake(20, 140, 220, 40);
    [play setTitle:@"Playback" forState:UIControlStateNormal];

    [p addSubview:start];
    [p addSubview:stop];
    [p addSubview:play];

    return p;
}

@end
